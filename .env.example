# ── Cortex engine — переменные окружения ──
# Этот файл = чек-лист того, что подменяется при переезде на инфру компании (Фаза 5B/5C).
# Реальный .env НЕ коммитить.

# База данных движка (PostgreSQL 16 + pgvector). Таблицы: documents, chunks, query_logs, api_keys.
DATABASE_URL=postgres://user:password@localhost:5432/cortex

# Провайдер LLM: yandex | gemini
AI_PROVIDER=yandex

# Yandex Cloud (RU)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_CHAT_MODEL=yandexgpt-lite
# YANDEX_DOC_EMBEDDING_MODEL=text-search-doc
# YANDEX_QUERY_EMBEDDING_MODEL=text-search-query

# Gemini (EN/Global) — нужен только при AI_PROVIDER=gemini
GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Адрес HTTP-сервера (host:port). Prod-дефолт меша — 0.0.0.0:8080.
SERVER_ADDRESS=0.0.0.0:8080

# CORS: список origin'ов поверхностей через запятую; "*" — только для dev.
CORS_ORIGINS=*

# Опционально — порог эскалации и часы работы оператора
# ESCALATION_SIMILARITY_THRESHOLD=0.3
# OPERATOR_BUSINESS_HOURS=9-21
# OPERATOR_BUSINESS_DAYS=1-5
